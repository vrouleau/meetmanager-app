# Meet Manager App — Environment Variables
# Copy to .env and fill in your values

# Admin PIN (used to log in as admin)
ADMIN_PIN=314159

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# Public URL of the frontend (used in email links)
APP_BASE_URL=http://localhost:8001

# Secret key for encrypting PINs in one-time links
SECRET_KEY=change-me-to-a-random-string

# Stripe (draft invoice creation) — secret key (sk_test_... or sk_live_...)
STRIPE_API_KEY=
